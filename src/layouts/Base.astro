---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  pageType?: 'website' | 'article';
  jsonLd?: Record<string, any> | Record<string, any>[];
}

const {
  title,
  description,
  canonical,
  ogImage = '/og-default.png',
  pageType = 'website',
  jsonLd,
} = Astro.props;

const siteName = 'AI Lean Solutions';
const fullTitle = title === 'home'
  ? `${siteName} — Competitive intelligence for local service businesses`
  : `${title} — ${siteName}`;

const canonicalUrl = canonical ?? new URL(Astro.url.pathname, Astro.site).toString();

// Organization JSON-LD (always present)
const orgLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'AI Lean Solutions LLC',
  url: 'https://www.aileansolutions.com',
  logo: 'https://www.aileansolutions.com/brand/logo.png',
  founder: {
    '@type': 'Person',
    name: 'Brian Bricker',
    jobTitle: 'Founder',
  },
  sameAs: [],
  contactPoint: {
    '@type': 'ContactPoint',
    contactType: 'customer support',
    email: 'Brian.Bricker@AILeansolutions.com',
  },
};

const ldStack = [orgLd, ...(jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [])];
---

<!doctype html>
<html lang="en" class="antialiased">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Theme color -->
    <meta name="theme-color" content="#0A0A0A" />

    <!-- OpenGraph -->
    <meta property="og:type" content={pageType} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, Astro.site).toString()} />
    <meta property="og:site_name" content={siteName} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, Astro.site).toString()} />

    <!-- Preconnect fonts for performance -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <!-- JSON-LD -->
    {ldStack.map((ld) => (
      <script type="application/ld+json" set:html={JSON.stringify(ld)} />
    ))}

    <!--
      Analytics placeholder — Plausible.
      Uncomment the line below after signing up at plausible.io and configuring
      the aileansolutions.com domain. No other tracking is used on this site.

      <script defer data-domain="aileansolutions.com" src="https://plausible.io/js/script.js"></script>
    -->
  </head>
  <body class="min-h-screen flex flex-col">
    <a href="#main" class="skip-link">Skip to content</a>

    <Nav />

    <main id="main" class="flex-1">
      <slot />
    </main>

    <Footer />
  </body>
</html>
