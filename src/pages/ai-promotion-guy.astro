---
import Base from '../layouts/Base.astro';
import Section from '../components/Section.astro';

const description = 'AI Promotion Guy is an AI Lean Solutions initiative helping everyday Americans and Main Street businesses get practical, confidence-building AI wins.';
---

<Base title="AI Promotion Guy" description={description}>
  <section class="relative overflow-hidden bg-[#07172f] pt-16 pb-20 md:pt-24 md:pb-28">
    <div class="absolute inset-0 bg-grid opacity-40"></div>
    <div class="container-site relative">
      <div class="inline-flex items-center gap-3 rounded-full bg-[#ffd23f] px-5 py-2 font-display text-[14px] font-extrabold text-[#251a00]">
        Practical AI for regular people
      </div>
      <h1 class="mt-8 font-display font-bold tracking-tightest text-[clamp(2.3rem,7vw,5.2rem)] leading-[0.98] max-w-[17ch] text-white">
        Helping America get its first useful AI win.
      </h1>
      <p class="mt-7 max-w-2xl text-[18px] md:text-[21px] leading-relaxed text-white/75">
        AI Promotion Guy is the public education and advocacy program for people who do not
        need more hype, doom, or technobabble. They need one useful result they can feel.
      </p>
      <div class="mt-10 flex flex-wrap gap-3">
        <a href="https://aipromotionguy.com/" target="_blank" rel="noopener" class="btn-primary">
          Visit AIPromotionGuy.com
        </a>
        <a href="#wins" class="btn-secondary">See the program</a>
      </div>
    </div>
  </section>

  <Section num="01" eyebrow="Program highlights" id="wins">
    <div class="grid gap-5 md:grid-cols-3">
      <div class="card p-7 border-[#ffd23f]/40">
        <div class="font-mono text-[11px] uppercase tracking-label text-[#ffd23f] mb-4">First wins</div>
        <h2 class="font-display text-2xl font-bold leading-tight">Small, visible AI wins.</h2>
        <p class="mt-3 text-text-muted text-[15px] leading-relaxed">
          Customer replies, meeting summaries, messy notes, starter plans, and plain-English
          explanations that show people AI can help before lunch.
        </p>
      </div>
      <div class="card p-7 border-[#32d3ff]/40">
        <div class="font-mono text-[11px] uppercase tracking-label text-[#32d3ff] mb-4">Main Street</div>
        <h2 class="font-display text-2xl font-bold leading-tight">Built beyond tech circles.</h2>
        <p class="mt-3 text-text-muted text-[15px] leading-relaxed">
          The audience is small business owners, working professionals, families, teachers,
          employees, and everyday Americans who want practical help.
        </p>
      </div>
      <div class="card p-7 border-[#ff7a1a]/40">
        <div class="font-mono text-[11px] uppercase tracking-label text-[#ff7a1a] mb-4">Responsible optimism</div>
        <h2 class="font-display text-2xl font-bold leading-tight">Pro-AI, not gullible.</h2>
        <p class="mt-3 text-text-muted text-[15px] leading-relaxed">
          The program teaches human judgment, privacy caution, verification, and practical
          use without making AI sound scary or magical.
        </p>
      </div>
    </div>
  </Section>

  <Section num="02" eyebrow="Signature idea">
    <div class="grid gap-10 md:grid-cols-[0.85fr_1.15fr] md:items-start">
      <h2 class="font-display font-bold tracking-tightest text-4xl md:text-5xl leading-[1.05]">
        W.I.N. with AI.
      </h2>
      <div class="grid gap-4">
        <div class="card p-6">
          <strong class="text-[#ffd23f]">Write better.</strong>
          <p class="mt-2 text-text-muted text-[15px]">Emails, scripts, proposals, job posts, customer replies, and plain-English explanations.</p>
        </div>
        <div class="card p-6">
          <strong class="text-[#32d3ff]">Interpret faster.</strong>
          <p class="mt-2 text-text-muted text-[15px]">Contracts, reviews, policies, notes, spreadsheets, and decisions hidden inside too much information.</p>
        </div>
        <div class="card p-6">
          <strong class="text-[#ff7a1a]">Next action.</strong>
          <p class="mt-2 text-text-muted text-[15px]">Turn overwhelm into a prioritized checklist a person can actually use today.</p>
        </div>
      </div>
    </div>
  </Section>
</Base>
