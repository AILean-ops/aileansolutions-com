---
import Base from '../layouts/Base.astro';

const description = 'Contact AI Lean Solutions LLC.';
---

<Base title="Contact" description={description}>

  <section class="relative overflow-hidden pt-16 pb-24 md:pt-24 md:pb-32 bg-grain">
    <div class="aurora"></div>
    <div class="absolute inset-0 bg-grid opacity-50"></div>
    <div class="container-site relative">
      <div class="max-w-3xl">
        <p class="section-label mb-5">// Contact</p>
        <h1 class="font-display font-bold tracking-tightest text-[clamp(2.2rem,6vw,5rem)] leading-[0.98] text-white">
          Send a note.
        </h1>
        <p class="mt-7 text-[18px] md:text-[21px] text-text-muted leading-relaxed">
          If you want to reach Brian about lean thinking, process improvement, practical AI,
          or a related conversation, use the form below.
        </p>
      </div>

      <div class="mt-12 grid gap-8 lg:grid-cols-[1.1fr_0.9fr] lg:items-start">
        <form
          id="contact-form"
          action="https://api.web3forms.com/submit"
          method="POST"
          novalidate
          class="card p-6 md:p-8 grid gap-5"
        >
          <input type="hidden" name="access_key" value="638f05ca-f33a-4c10-bba2-cc0c4e757cb1" />
          <input type="hidden" name="from_name" value="AI Lean Solutions contact form" />
          <input type="hidden" name="subject" value="[AI Lean Solutions] Website contact" />
          <input type="hidden" name="source_url" id="source_url" />

          <label class="block">
            <span class="block font-mono text-[11px] uppercase tracking-label text-text-muted mb-2">Name</span>
            <input
              name="name"
              required
              autocomplete="name"
              class="w-full px-4 py-3 bg-ink-800 border border-white/10 rounded-lg font-sans text-white placeholder:text-text-dim focus:border-brand-cyan focus:outline-none focus:ring-2 focus:ring-brand-cyan/20 transition-colors"
            />
          </label>

          <label class="block">
            <span class="block font-mono text-[11px] uppercase tracking-label text-text-muted mb-2">Email</span>
            <input
              name="email"
              type="email"
              required
              autocomplete="email"
              class="w-full px-4 py-3 bg-ink-800 border border-white/10 rounded-lg font-sans text-white placeholder:text-text-dim focus:border-brand-cyan focus:outline-none focus:ring-2 focus:ring-brand-cyan/20 transition-colors"
            />
          </label>

          <label class="block">
            <span class="block font-mono text-[11px] uppercase tracking-label text-text-muted mb-2">Message</span>
            <textarea
              name="message"
              required
              rows="6"
              class="w-full px-4 py-3 bg-ink-800 border border-white/10 rounded-lg font-sans text-white placeholder:text-text-dim focus:border-brand-cyan focus:outline-none focus:ring-2 focus:ring-brand-cyan/20 transition-colors resize-none"
              placeholder="A short note is enough."
            ></textarea>
          </label>

          <input type="checkbox" name="botcheck" style="display:none" tabindex="-1" autocomplete="off" />

          <div class="flex flex-wrap items-center gap-4 pt-2">
            <button type="submit" class="btn-primary">Send message</button>
          </div>
        </form>

        <aside class="card p-6 md:p-8">
          <p class="section-label mb-4">// Response</p>
          <div class="space-y-5 text-[15px] leading-relaxed text-text-muted">
            <p>
              This form goes to Brian Bricker at AI Lean Solutions. It is intentionally simple:
              no newsletter trap, no intake maze, no automated promise.
            </p>
            <p>
              If the note is a fit for a real conversation, Brian will reply directly.
            </p>
          </div>
        </aside>
      </div>

      <div id="contact-thanks" class="hidden mt-14 max-w-2xl">
        <div class="card p-8 md:p-10">
          <p class="font-mono text-[11px] uppercase tracking-label text-signal-up mb-4">Message sent</p>
          <h2 class="font-display text-3xl font-bold tracking-tight">Thank you. Brian received your note.</h2>
        </div>
      </div>

      <div id="contact-fallback" class="hidden mt-8 max-w-2xl">
        <div class="card p-6 border-amber-accent/30">
          <p class="text-[15px] leading-relaxed">
            Something went wrong sending that. Please email
            <a href="mailto:Brian.Bricker@AILeansolutions.com" class="text-brand-cyan underline underline-offset-4">
              Brian.Bricker@AILeansolutions.com</a>.
          </p>
        </div>
      </div>
    </div>
  </section>

  <script is:inline>
    (function () {
      const form = document.getElementById('contact-form');
      const thanks = document.getElementById('contact-thanks');
      const fallback = document.getElementById('contact-fallback');
      const source = document.getElementById('source_url');
      if (!form) return;
      source.value = window.location.href;

      form.addEventListener('submit', async function (event) {
        event.preventDefault();
        if (form.botcheck && form.botcheck.checked) return;

        const button = form.querySelector('button[type=submit]');
        const originalLabel = button.textContent;
        button.disabled = true;
        button.textContent = 'Sending...';

        try {
          const data = new FormData(form);
          const payload = {};
          data.forEach((value, key) => { payload[key] = value; });
          const response = await fetch(form.action, {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
              Accept: 'application/json',
            },
            body: JSON.stringify(payload),
          });
          const result = await response.json().catch(() => ({}));
          if (!response.ok || result.success === false) throw new Error(result.message || 'not ok');
          form.classList.add('hidden');
          thanks.classList.remove('hidden');
          thanks.scrollIntoView({ behavior: 'smooth', block: 'start' });
        } catch (error) {
          button.disabled = false;
          button.textContent = originalLabel;
          fallback.classList.remove('hidden');
        }
      });
    })();
  </script>

</Base>
