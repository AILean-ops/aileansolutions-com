---
import Base from '../layouts/Base.astro';

const description = "Talk to Brian. Founder reads every message — no bots, no SDR queue. Reply within business hours Pacific.";

/*
  FORM WIRING NOTE
  ----------------
  Posts directly to Web3Forms — same access key as /signup. Submissions land
  in Brian's aileansolutions.com Gmail.

  Access key: 638f05ca-f33a-4c10-bba2-cc0c4e757cb1
  See src/pages/signup.astro for full Web3Forms config notes.
*/
---

<Base title="Contact" description={description}>

  <section class="relative overflow-hidden pt-16 pb-24 md:pt-24 md:pb-32 bg-grain">
    <div class="aurora"></div>
    <div class="container-site relative">

      <div class="max-w-2xl">
        <p class="section-label mb-6">// Contact</p>
        <h1 class="font-display font-bold tracking-tightest text-[clamp(2rem,6vw,4.5rem)] leading-[1.02]">
          Talk to Brian.
        </h1>
        <p class="mt-6 text-[17px] text-text-muted leading-relaxed max-w-prose">
          Founder reads every message. No bots, no SDR queue, no "contact us" funnel
          that ends in a calendar widget. Just write what's on your mind.
        </p>
      </div>

      <!-- FORM -->
      <form
        id="contact-form"
        action="https://api.web3forms.com/submit"
        method="POST"
        novalidate
        class="mt-14 max-w-2xl grid gap-5"
      >
        <!-- Web3Forms hidden fields -->
        <input type="hidden" name="access_key" value="638f05ca-f33a-4c10-bba2-cc0c4e757cb1" />
        <input type="hidden" name="from_name" value="aileansolutions.com contact form" />
        <input type="hidden" name="subject" value="[Contact] aileansolutions.com message" />

        <div class="grid md:grid-cols-2 gap-5">
          <label class="block">
            <span class="block font-mono text-[11px] uppercase tracking-label text-text-muted mb-2">Name</span>
            <input
              type="text"
              name="name"
              required
              autocomplete="name"
              class="w-full px-4 py-3 bg-ink-800 border border-white/10 rounded-lg font-sans text-white placeholder:text-text-dim focus:border-brand-cyan focus:outline-none focus:ring-2 focus:ring-brand-cyan/20 transition-colors"
              placeholder="Jamie Ortega"
            />
          </label>
          <label class="block">
            <span class="block font-mono text-[11px] uppercase tracking-label text-text-muted mb-2">Email</span>
            <input
              type="email"
              name="email"
              required
              autocomplete="email"
              class="w-full px-4 py-3 bg-ink-800 border border-white/10 rounded-lg font-sans text-white placeholder:text-text-dim focus:border-brand-cyan focus:outline-none focus:ring-2 focus:ring-brand-cyan/20 transition-colors"
              placeholder="jamie@studio.co"
            />
          </label>
        </div>

        <label class="block">
          <span class="block font-mono text-[11px] uppercase tracking-label text-text-muted mb-2">Company <span class="normal-case tracking-normal text-text-dim">(optional)</span></span>
          <input
            type="text"
            name="company"
            autocomplete="organization"
            class="w-full px-4 py-3 bg-ink-800 border border-white/10 rounded-lg font-sans text-white placeholder:text-text-dim focus:border-brand-cyan focus:outline-none focus:ring-2 focus:ring-brand-cyan/20 transition-colors"
            placeholder="Studio Name, Inc."
          />
        </label>

        <label class="block">
          <span class="block font-mono text-[11px] uppercase tracking-label text-text-muted mb-2">Message</span>
          <textarea
            name="message"
            rows="6"
            required
            class="w-full px-4 py-3 bg-ink-800 border border-white/10 rounded-lg font-sans text-white placeholder:text-text-dim focus:border-brand-cyan focus:outline-none focus:ring-2 focus:ring-brand-cyan/20 transition-colors resize-none"
            placeholder="Question, feedback, pricing request, want intelligence in your market — whatever's on your mind."
          ></textarea>
        </label>

        <!-- Web3Forms honeypot (spam trap) -->
        <input type="checkbox" name="botcheck" style="display:none" tabindex="-1" autocomplete="off" />

        <div class="flex flex-wrap items-center gap-4 pt-2">
          <button type="submit" class="btn-primary">
            Send message
            <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
              <path d="M2 6h8m-3-3 3 3-3 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
          <p class="text-[13px] text-text-muted">
            Quiet hours respected. Replies during business hours Pacific.
          </p>
        </div>
      </form>

      <!-- THANK-YOU -->
      <div id="contact-thanks" class="hidden mt-14 max-w-2xl">
        <div class="card p-8 md:p-10">
          <div class="flex items-center gap-3 mb-5">
            <span class="inline-flex w-8 h-8 rounded-full bg-signal-up/15 text-signal-up items-center justify-center">
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                <path d="M2 7.5 5.5 11 12 3.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>
            <p class="font-mono text-[11px] uppercase tracking-label text-signal-up">Message sent</p>
          </div>
          <h2 class="font-display text-3xl font-bold tracking-tight">Got it. Thanks.</h2>
          <p class="mt-4 text-text-muted text-[16px] leading-relaxed">
            Brian will read it personally and reply during business hours Pacific &mdash;
            usually same day, occasionally next.
          </p>
        </div>
      </div>

      <!-- ERROR / FALLBACK -->
      <div id="contact-fallback" class="hidden mt-8 max-w-2xl">
        <div class="card p-6 border-amber-accent/30">
          <p class="text-[15px] leading-relaxed">
            Something went wrong sending that &mdash; please email Brian directly at
            <a href="mailto:Brian.Bricker@AILeansolutions.com" class="text-brand-cyan underline underline-offset-4">
              Brian.Bricker@AILeansolutions.com</a> and he&rsquo;ll get back to you.
          </p>
        </div>
      </div>

      <!-- Mailto fallback link, always visible below the form -->
      <div class="hairline mt-14 pt-8 max-w-2xl">
        <p class="font-mono text-[11px] uppercase tracking-label text-text-muted mb-2">Prefer email?</p>
        <p class="text-[15px] leading-relaxed">
          Write Brian directly at
          <a href="mailto:Brian.Bricker@AILeansolutions.com?subject=Hello%20from%20the%20AI%20Lean%20site" class="text-white underline underline-offset-4 decoration-white/30 hover:decoration-white">
            Brian.Bricker@AILeansolutions.com</a>.
        </p>
      </div>

    </div>
  </section>

  <script is:inline>
    (function () {
      const form = document.getElementById('contact-form');
      const thanks = document.getElementById('contact-thanks');
      const fallback = document.getElementById('contact-fallback');
      if (!form) return;

      form.addEventListener('submit', async function (e) {
        e.preventDefault();
        if (form.botcheck && form.botcheck.checked) return;

        const btn = form.querySelector('button[type=submit]');
        const originalLabel = btn.innerHTML;
        btn.disabled = true;
        btn.innerHTML = 'Sending…';

        try {
          const data = new FormData(form);
          const obj = {};
          data.forEach((v, k) => { obj[k] = v; });
          const res = await fetch(form.action, {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
              Accept: 'application/json',
            },
            body: JSON.stringify(obj),
          });
          const json = await res.json().catch(() => ({}));
          if (!res.ok || json.success === false) throw new Error(json.message || 'not ok');
          form.classList.add('hidden');
          thanks.classList.remove('hidden');
          thanks.scrollIntoView({ behavior: 'smooth', block: 'start' });
        } catch (err) {
          btn.disabled = false;
          btn.innerHTML = originalLabel;
          fallback.classList.remove('hidden');
        }
      });
    })();
  </script>

</Base>
