---
import Base from '../../layouts/Base.astro';

const description = "Privacy policy for AI Lean Solutions LLC. What we collect, how we use it, and who we share it with. Short version: as little as possible, for the thing you signed up for, and nobody.";
---

<Base title="Privacy" description={description}>

  <section class="pt-16 pb-24 md:pt-24 md:pb-32">
    <div class="container-site max-w-prose">

      <p class="section-label mb-4">// Legal</p>
      <h1 class="font-display font-bold tracking-tightest text-[clamp(2rem,5vw,3.5rem)] leading-[1.05]">
        Privacy policy
      </h1>
      <p class="mt-3 text-[14px] text-text-muted font-mono">
        Last updated: April 2026
      </p>

      <div class="mt-10 space-y-8 text-[16px] leading-relaxed text-white/85">

        <div>
          <h2 class="font-display text-2xl font-semibold text-white mb-3">Who we are</h2>
          <p>
            AI Lean Solutions LLC ("we," "us") is a US limited liability company based in
            Sacramento, California. We operate <a href="https://www.aileansolutions.com" class="underline underline-offset-4 decoration-white/30 hover:decoration-white">aileansolutions.com</a>
            and deliver competitive intelligence reports to subscribers by email.
          </p>
        </div>

        <div>
          <h2 class="font-display text-2xl font-semibold text-white mb-3">What we collect</h2>
          <p>
            From site visitors: nothing beyond what your browser sends (IP, user agent,
            referrer). We use a privacy-respecting analytics tool (Plausible) that does not
            set cookies and does not identify you personally. We do not run Google Analytics,
            Facebook Pixel, or any other tracking-style analytics.
          </p>
          <p class="mt-3">
            From waitlist signups: your name, email, business type, city/metro, and any
            optional comments you choose to include.
          </p>
          <p class="mt-3">
            From paying subscribers (once we launch): billing details handled by our payment
            processor (we never see or store card numbers), plus the operational details
            needed to tailor your weekly report (your business name, location, and competitor
            list).
          </p>
        </div>

        <div>
          <h2 class="font-display text-2xl font-semibold text-white mb-3">How we use it</h2>
          <p>
            To deliver the product. Emails go to the address you signed up with. Subscription
            details are used to generate your weekly report. We don't sell, rent, or share
            your data with advertisers. We don't share it across subscriber accounts.
          </p>
        </div>

        <div>
          <h2 class="font-display text-2xl font-semibold text-white mb-3">Who we share it with</h2>
          <p>
            Only the service providers we need to operate: our email delivery provider, our
            payment processor, and our hosting provider. Each of them has their own privacy
            policy and processes data on our behalf under a data processing agreement.
          </p>
        </div>

        <div>
          <h2 class="font-display text-2xl font-semibold text-white mb-3">How long we keep it</h2>
          <p>
            Waitlist entries: until you unsubscribe, then 30 days, then purged. Subscriber
            records: for the duration of your subscription, plus tax-record retention required
            by law after cancellation.
          </p>
        </div>

        <div>
          <h2 class="font-display text-2xl font-semibold text-white mb-3">Your rights</h2>
          <p>
            You can request access to, correction of, or deletion of your data by emailing
            <a href="mailto:Brian.Bricker@AILeansolutions.com" class="underline underline-offset-4 decoration-white/30 hover:decoration-white">Brian.Bricker@AILeansolutions.com</a>.
            We respond within a reasonable period. Depending on your jurisdiction (California,
            EU/UK, etc.) you may have additional rights under CCPA, GDPR, or similar — we'll
            honor them.
          </p>
        </div>

        <div>
          <h2 class="font-display text-2xl font-semibold text-white mb-3">Cookies</h2>
          <p>
            We don't use any. If that ever changes, we'll say so here and ask for consent
            where required.
          </p>
        </div>

        <div>
          <h2 class="font-display text-2xl font-semibold text-white mb-3">Changes</h2>
          <p>
            If we update this policy, we'll update the "last updated" date and, for material
            changes, notify active subscribers by email.
          </p>
        </div>

        <div>
          <h2 class="font-display text-2xl font-semibold text-white mb-3">Contact</h2>
          <p>
            Privacy questions go to
            <a href="mailto:Brian.Bricker@AILeansolutions.com" class="underline underline-offset-4 decoration-white/30 hover:decoration-white">Brian.Bricker@AILeansolutions.com</a>.
          </p>
        </div>

      </div>
    </div>
  </section>

</Base>
