---
import Base from '../../layouts/Base.astro';

const description = "Privacy policy for AI Lean Solutions LLC. What we collect, how we use it, and who we share it with.";
---

<Base title="Privacy" description={description}>

  <section class="pt-16 pb-24 md:pt-24 md:pb-32">
    <div class="container-site max-w-prose">

      <p class="section-label mb-4">// Legal</p>
      <h1 class="font-display font-bold tracking-tightest text-[clamp(2rem,5vw,3.5rem)] leading-[1.05]">
        Privacy policy
      </h1>
      <p class="mt-3 text-[14px] text-text-muted font-mono">
        Last updated: June 2026
      </p>

      <div class="mt-10 space-y-8 text-[16px] leading-relaxed text-white/85">

        <div>
          <h2 class="font-display text-2xl font-semibold text-white mb-3">Who we are</h2>
          <p>
            AI Lean Solutions LLC ("we," "us") is a US limited liability company based in
            Sacramento, California. We operate <a href="https://www.aileansolutions.com" class="underline underline-offset-4 decoration-white/30 hover:decoration-white">aileansolutions.com</a>
            as the parent-company site for AI Promotion Guy and UsefulOps AI.
          </p>
        </div>

        <div>
          <h2 class="font-display text-2xl font-semibold text-white mb-3">What we collect</h2>
          <p>
            From visitors to this site: nothing beyond what your browser sends to load a web
            page, such as IP address, user agent, and referrer. This site does not use cookies,
            Google Analytics, Facebook Pixel, or advertising trackers.
          </p>
          <p class="mt-3">
            If you contact us by email or use an operational form linked from an existing
            service email, we receive the information you choose to provide.
          </p>
          <p class="mt-3">
            AI Promotion Guy and UsefulOps AI may have their own forms, intake flows, or
            service records. Those sites collect only what is needed for the request or service
            you submit there.
          </p>
        </div>

        <div>
          <h2 class="font-display text-2xl font-semibold text-white mb-3">How we use it</h2>
          <p>
            To respond to your request, operate our sites, provide services you asked for,
            and maintain basic business records. We do not sell, rent, or share your data with
            advertisers.
          </p>
        </div>

        <div>
          <h2 class="font-display text-2xl font-semibold text-white mb-3">Who we share it with</h2>
          <p>
            Only the service providers we need to operate, such as website hosting, email,
            forms, scheduling, and payment providers where applicable. Each provider processes
            data on our behalf or under its own published terms.
          </p>
        </div>

        <div>
          <h2 class="font-display text-2xl font-semibold text-white mb-3">How long we keep it</h2>
          <p>
            We keep messages, form submissions, service records, and business records only as
            long as needed for the purpose collected, normal business administration, legal
            compliance, or tax-record retention.
          </p>
        </div>

        <div>
          <h2 class="font-display text-2xl font-semibold text-white mb-3">Your rights</h2>
          <p>
            You can request access to, correction of, or deletion of your data by emailing
            <a href="mailto:Brian.Bricker@AILeansolutions.com" class="underline underline-offset-4 decoration-white/30 hover:decoration-white">Brian.Bricker@AILeansolutions.com</a>.
            We respond within a reasonable period. Depending on your jurisdiction (California,
            EU/UK, etc.) you may have additional rights under CCPA, GDPR, or similar — we'll
            honor them.
          </p>
        </div>

        <div>
          <h2 class="font-display text-2xl font-semibold text-white mb-3">Cookies</h2>
          <p>
            We don't use any. If that ever changes, we'll say so here and ask for consent
            where required.
          </p>
        </div>

        <div>
          <h2 class="font-display text-2xl font-semibold text-white mb-3">Changes</h2>
          <p>
            If we update this policy, we'll update the "last updated" date.
          </p>
        </div>

        <div>
          <h2 class="font-display text-2xl font-semibold text-white mb-3">Contact</h2>
          <p>
            Privacy questions go to
            <a href="mailto:Brian.Bricker@AILeansolutions.com" class="underline underline-offset-4 decoration-white/30 hover:decoration-white">Brian.Bricker@AILeansolutions.com</a>.
          </p>
        </div>

      </div>
    </div>
  </section>

</Base>
