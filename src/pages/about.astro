---
import Base from '../layouts/Base.astro';
import Section from '../components/Section.astro';

const description = "Brian Bricker — 20+ years running operations and improving how businesses work. Why he built AI Lean Solutions, and what the company believes.";
---

<Base title="About" description={description}>

  <!-- Editorial hero — light mode, warm -->
  <section class="relative bg-paper-100 text-text-dark overflow-hidden">
    <div class="container-site relative pt-20 pb-16 md:pt-28 md:pb-24">

      <div class="grid md:grid-cols-[1fr_1.4fr] gap-12 md:gap-16 items-start">

        <!-- Photo column -->
        <div>
          <div class="aspect-[4/5] relative rounded-2xl overflow-hidden bg-paper-200 shadow-xl">
            <img
              src="/brand/brian-paris.jpg"
              alt="Brian Bricker, founder of AI Lean Solutions"
              class="absolute inset-0 w-full h-full object-cover"
              width="800"
              height="1000"
              loading="eager"
              onerror="this.style.display='none'; this.parentNode.querySelector('.photo-fallback').style.display='grid';"
            />
            <div class="photo-fallback absolute inset-0 hidden place-items-center text-center p-8 bg-paper-200 text-text-dark/40">
              <div>
                <div class="font-mono text-[11px] uppercase tracking-label">Placeholder</div>
                <p class="mt-2 text-[13px]">Drop <code>brian-paris.jpg</code> in <code>/public/brand/</code></p>
              </div>
            </div>
          </div>
          <p class="mt-4 font-mono text-[11px] uppercase tracking-label text-text-dark/60">
            Brian Bricker · Founder &amp; CEO
          </p>
        </div>

        <!-- Story column -->
        <div>
          <p class="font-mono text-[11px] uppercase tracking-label text-amber-accent mb-5">
            // Brian's story
          </p>
          <h1 class="font-display font-bold tracking-tightest text-[clamp(2rem,5vw,3.75rem)] leading-[1.02] text-text-dark">
            Twenty years running operations<br/>taught me one thing:
            <span class="italic font-normal">small businesses lose when they don&rsquo;t know what their competitors are doing.</span>
          </h1>

          <div class="mt-8 space-y-5 text-[17px] leading-relaxed text-text-dark/80 max-w-prose">
            <p>
              I&rsquo;m Brian Bricker. I&rsquo;ve spent my career in process improvement, operations,
              and business leadership &mdash; two decades of walking into rooms where a small team
              was getting beaten by a bigger team that simply had better information.
            </p>
            <p>
              The pattern was always the same. The owner of the small shop knew their product cold.
              What they didn&rsquo;t know: what their closest competitors were charging yesterday.
              Who just hired a new staff member across town. Which of them quietly raised prices.
              Which of them got hit with a wave of bad reviews and is about to start discounting.
            </p>
            <p>
              The chains knew all of it. They had someone whose full-time job was knowing it. The
              small business owner had a business to run &mdash; so they didn&rsquo;t watch, and the
              gap quietly grew until one day it became a real problem.
            </p>
            <p>
              AI Lean Solutions exists to close that gap. We track your real competitors every
              week and deliver one email you can read in about six minutes. It&rsquo;s not a
              dashboard. It&rsquo;s not a consulting engagement. It&rsquo;s weekly competitive
              intelligence from someone who&rsquo;s paying attention so you don&rsquo;t have to.
            </p>
            <p class="font-display text-[19px] font-medium text-text-dark">
              &mdash; Brian
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Mission -->
  <Section num="01" eyebrow="Mission">
    <div class="grid md:grid-cols-[1fr_1.3fr] gap-12 items-start">
      <h2 class="font-display font-bold tracking-tightest text-4xl md:text-5xl leading-[1.05]">
        Give every local business owner the awareness a Fortune 500 takes for granted.
      </h2>
      <p class="text-text-muted text-[17px] leading-relaxed">
        Big chains get daily competitor dashboards. Regional franchises get quarterly market
        reports. The single-location med spa owner, the two-chair dental practice, the family
        HVAC shop &mdash; they get a gut feeling and a Google search when something goes wrong.
        We&rsquo;re closing that gap, one industry and one city at a time, with reports written
        in plain language by someone who&rsquo;s actually run the kind of business they&rsquo;re
        reading about.
      </p>
    </div>
  </Section>

  <!-- Values -->
  <Section num="02" eyebrow="What we actually believe">
    <h2 class="font-display font-bold tracking-tightest text-4xl md:text-5xl leading-[1.05] max-w-[22ch]">
      Straight talk, not marketing talk.
    </h2>
    <p class="mt-5 text-text-muted text-[17px] leading-relaxed max-w-prose">
      Three commitments. Short enough to remember, concrete enough to hold us to.
    </p>

    <div class="mt-12 grid gap-4 md:grid-cols-3">
      <div class="card p-7 relative">
        <span class="absolute top-5 right-5 font-mono text-[40px] leading-none text-brand-cyan/20">01</span>
        <h3 class="font-display text-xl font-semibold">We only send things we&rsquo;d actually read.</h3>
        <p class="mt-3 text-text-muted text-[15px] leading-relaxed">
          If a paragraph wouldn&rsquo;t hold our own attention on a busy weekday morning, it
          doesn&rsquo;t go in. Every email is reviewed by Brian before it goes out.
        </p>
      </div>
      <div class="card p-7 relative">
        <span class="absolute top-5 right-5 font-mono text-[40px] leading-none text-brand-cyan/20">02</span>
        <h3 class="font-display text-xl font-semibold">Cancel anytime. No contracts.</h3>
        <p class="mt-3 text-text-muted text-[15px] leading-relaxed">
          Month-to-month. No minimum term. No cancellation fee. If the reports stop being useful,
          you stop paying. That&rsquo;s the whole arrangement.
        </p>
      </div>
      <div class="card p-7 relative">
        <span class="absolute top-5 right-5 font-mono text-[40px] leading-none text-brand-cyan/20">03</span>
        <h3 class="font-display text-xl font-semibold">No sales calls. Ever.</h3>
        <p class="mt-3 text-text-muted text-[15px] leading-relaxed">
          Reading is faster than talking. If you have questions, Brian answers email. If you
          want a demo, there isn&rsquo;t one &mdash; the sample report is the demo.
        </p>
      </div>
    </div>
  </Section>

  <!-- Company facts -->
  <Section num="03" eyebrow="Company">
    <div class="grid md:grid-cols-4 gap-6 text-[14px]">
      <div>
        <div class="font-mono text-[11px] uppercase tracking-label text-text-muted mb-1.5">Entity</div>
        <div class="font-display text-lg">AI Lean Solutions LLC</div>
      </div>
      <div>
        <div class="font-mono text-[11px] uppercase tracking-label text-text-muted mb-1.5">Founded</div>
        <div class="font-display text-lg">2025</div>
      </div>
      <div>
        <div class="font-mono text-[11px] uppercase tracking-label text-text-muted mb-1.5">Based</div>
        <div class="font-display text-lg">Sacramento, CA</div>
      </div>
      <div>
        <div class="font-mono text-[11px] uppercase tracking-label text-text-muted mb-1.5">Status</div>
        <div class="font-display text-lg">Live in Phoenix · Med spas</div>
      </div>
    </div>
  </Section>

</Base>
