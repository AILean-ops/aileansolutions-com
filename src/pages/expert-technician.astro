---
import Base from '../layouts/Base.astro';
import Section from '../components/Section.astro';

const description = 'Expert Technician is an AI Lean Solutions initiative piloting 24/7 technical and troubleshooting support for US-based HVAC technicians.';
---

<Base title="Expert Technician" description={description}>
  <section class="relative overflow-hidden pt-16 pb-20 md:pt-24 md:pb-28 bg-[#101114]">
    <div class="absolute inset-0 bg-grid opacity-35"></div>
    <div class="container-site relative">
      <div class="inline-flex items-center gap-2 border border-[#f97316]/40 bg-[#f97316]/10 px-4 py-2 font-mono text-[11px] uppercase tracking-label text-[#fb923c]">
        Pilot now forming · US-based HVAC technicians
      </div>
      <h1 class="mt-8 font-display font-bold tracking-tightest text-[clamp(2.3rem,7vw,5.2rem)] leading-[0.98] max-w-[17ch] text-white">
        Expert troubleshooting support, available when the job is not waiting.
      </h1>
      <p class="mt-7 max-w-2xl text-[18px] md:text-[21px] leading-relaxed text-text-muted">
        Expert Technician gives field technicians a 24/7 support line for technical questions,
        troubleshooting guidance, and real-time resources sent directly to email.
      </p>
      <div class="mt-10 flex flex-wrap gap-3">
        <a href="mailto:Brian.Bricker@AILeansolutions.com?subject=Expert%20Technician%20HVAC%20pilot" class="btn-primary">
          Ask about the HVAC pilot
        </a>
        <a href="#pilot" class="btn-secondary">How it helps</a>
      </div>
    </div>
  </section>

  <Section num="01" eyebrow="Field support" id="pilot">
    <div class="grid gap-5 md:grid-cols-3">
      <div class="card p-7 border-[#f97316]/35">
        <div class="font-mono text-[11px] uppercase tracking-label text-[#fb923c] mb-4">No wait times</div>
        <h2 class="font-display text-2xl font-bold leading-tight">Support when the technician calls.</h2>
        <p class="mt-3 text-text-muted text-[15px] leading-relaxed">
          The goal is immediate access to technical and troubleshooting guidance without waiting
          for a senior tech, trainer, or manufacturer line to become available.
        </p>
      </div>
      <div class="card p-7 border-[#38bdf8]/35">
        <div class="font-mono text-[11px] uppercase tracking-label text-[#38bdf8] mb-4">Real-time resources</div>
        <h2 class="font-display text-2xl font-bold leading-tight">Guidance plus follow-up material.</h2>
        <p class="mt-3 text-text-muted text-[15px] leading-relaxed">
          Technicians can receive relevant troubleshooting steps, reference material, and job-support
          resources by email while the issue is still fresh.
        </p>
      </div>
      <div class="card p-7 border-[#22c55e]/35">
        <div class="font-mono text-[11px] uppercase tracking-label text-[#22c55e] mb-4">Pilot focus</div>
        <h2 class="font-display text-2xl font-bold leading-tight">Starting with HVAC.</h2>
        <p class="mt-3 text-text-muted text-[15px] leading-relaxed">
          AI Lean Solutions is currently piloting the system for US-based HVAC technicians
          and companies that want faster support in the field.
        </p>
      </div>
    </div>
  </Section>

  <Section num="02" eyebrow="Who should contact us">
    <div class="grid gap-10 md:grid-cols-[0.9fr_1.1fr] md:items-start">
      <h2 class="font-display font-bold tracking-tightest text-4xl md:text-5xl leading-[1.05]">
        Interested HVAC techs and service companies are invited into the pilot.
      </h2>
      <div class="space-y-6">
        <p class="text-text-muted text-[17px] leading-relaxed">
          The best pilot participants are technicians, trainers, owners, or service managers
          who see where troubleshooting delays create callbacks, escalations, downtime, or
          pressure on senior team members.
        </p>
        <div class="card p-6">
          <p class="font-display text-xl font-semibold">Contact Brian Bricker</p>
          <p class="mt-2 text-text-muted text-[15px]">Ask for more information or share interest in participating in the Expert Technician HVAC pilot.</p>
          <a href="mailto:Brian.Bricker@AILeansolutions.com?subject=Expert%20Technician%20HVAC%20pilot" class="btn-primary mt-5">
            Brian.Bricker@AILeansolutions.com
          </a>
        </div>
      </div>
    </div>
  </Section>
</Base>
