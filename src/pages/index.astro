---
import Base from '../layouts/Base.astro';
import Section from '../components/Section.astro';

const description = 'AI Lean Solutions LLC helps people and small businesses think more clearly about work, process improvement, and practical AI adoption.';

const principles = [
  {
    label: 'Lean thinking',
    title: 'Make work visible',
    copy: 'Before adding tools, clarify the work: what happens, where it waits, what repeats, and what creates value.',
  },
  {
    label: 'Process improvement',
    title: 'Remove friction',
    copy: 'Small improvements compound when the process is clear, the handoffs are simple, and the next step is obvious.',
  },
  {
    label: 'Practical AI',
    title: 'Use AI where it helps',
    copy: 'AI is most useful when it reduces busywork, improves communication, supports judgment, and helps people move with confidence.',
  },
];
---

<Base title="home" description={description}>

  <section class="relative overflow-hidden pt-16 pb-20 md:pt-24 md:pb-28 bg-grain">
    <div class="aurora"></div>
    <div class="absolute inset-0 bg-grid opacity-50"></div>
    <div class="container-site relative">
      <div class="grid gap-14 lg:grid-cols-[1.1fr_0.9fr] lg:items-end">
        <div>
          <p class="section-label mb-6">// AI Lean Solutions LLC</p>
          <h1 class="font-display font-bold tracking-tightest text-[clamp(2.7rem,7vw,6.4rem)] leading-[0.96] text-white max-w-[11ch]">
            Better work with clearer thinking and practical AI.
          </h1>
          <p class="mt-8 max-w-2xl text-[18px] md:text-[21px] text-text-muted leading-relaxed">
            AI Lean Solutions brings together lean thinking, process improvement, and
            practical AI education to help everyday people and small businesses make sense of
            changing technology without losing sight of the human work.
          </p>
          <div class="mt-10 flex flex-wrap items-center gap-3">
            <a href="/about" class="btn-primary">About Brian</a>
            <a href="/contact" class="btn-secondary">Contact</a>
          </div>
        </div>

        <div class="grid gap-4">
          <div class="card p-6 md:p-7">
            <p class="section-label mb-4">// Focus</p>
            <p class="font-display text-3xl md:text-4xl font-bold tracking-tight leading-tight">
              Helping people understand AI, improve work, and choose better next steps.
            </p>
          </div>
          <div class="grid grid-cols-2 gap-4">
            <div class="card p-5">
              <p class="font-mono text-[11px] uppercase tracking-label text-brand-cyan">Approach</p>
              <p class="mt-2 font-display text-2xl font-bold">Lean</p>
            </div>
            <div class="card p-5">
              <p class="font-mono text-[11px] uppercase tracking-label text-[#ffd23f]">Standard</p>
              <p class="mt-2 font-display text-2xl font-bold">Useful</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <Section num="01" eyebrow="Operating Philosophy">
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-12">
      <h2 class="font-display font-bold tracking-tightest text-4xl md:text-5xl max-w-[16ch] leading-[1.05]">
        Technology works best when the work is understood first.
      </h2>
      <p class="text-text-muted text-[16px] max-w-md leading-relaxed">
        The center of gravity is not hype. It is useful work: fewer delays, cleaner
        communication, better decisions, and more confidence for the people doing the work.
      </p>
    </div>

    <div class="grid gap-5 md:grid-cols-3">
      {principles.map((item) => (
        <article class="card p-7 md:p-8">
          <p class="font-mono text-[11px] uppercase tracking-label text-brand-cyan">{item.label}</p>
          <h3 class="mt-5 font-display text-3xl font-bold tracking-tight leading-none">{item.title}</h3>
          <p class="mt-5 text-text-muted text-[16px] leading-relaxed">{item.copy}</p>
        </article>
      ))}
    </div>
  </Section>

  <Section num="02" eyebrow="Why It Matters">
    <div class="grid gap-10 lg:grid-cols-[0.8fr_1.2fr] lg:items-start">
      <h2 class="font-display font-bold tracking-tightest text-4xl md:text-5xl leading-[1.05]">
        AI should feel practical, understandable, and grounded in real life.
      </h2>
      <div class="space-y-7 text-[17px] leading-relaxed text-text-muted">
        <p>
          For most people and small businesses, AI adoption will not be a grand transformation
          project. It will be a hundred small moments: writing something clearer, finding the
          right question, organizing a messy process, preparing a better first draft, or seeing
          a workflow from a different angle.
        </p>
        <p>
          AI Lean Solutions exists to promote that kind of practical adoption: optimistic
          without being naive, process-minded without being stiff, and focused on helping
          normal people get real benefit from new tools.
        </p>
      </div>
    </div>
  </Section>

  <section class="relative overflow-hidden">
    <div class="container-site py-20 md:py-28">
      <div class="relative border border-white/8 bg-gradient-to-br from-ink-800 to-ink-900 p-8 md:p-12 overflow-hidden">
        <div class="absolute inset-x-0 top-0 h-1 bg-gradient-to-r from-brand-cyan via-[#ffd23f] to-[#f97316]"></div>
        <div class="relative max-w-2xl">
          <p class="section-label mb-4">Contact</p>
          <h2 class="font-display font-bold tracking-tightest text-4xl md:text-5xl leading-[1.05]">
            A simple place to start.
          </h2>
          <p class="mt-5 text-text-muted text-[17px] leading-relaxed">
            If something here connects with a problem you are thinking through, send a note.
            The public site stays intentionally broad; the conversation can get specific.
          </p>
          <div class="mt-8">
            <a href="/contact" class="btn-primary">Send a note</a>
          </div>
        </div>
      </div>
    </div>
  </section>

</Base>
