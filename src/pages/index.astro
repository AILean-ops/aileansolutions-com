---
import Base from '../layouts/Base.astro';
import Section from '../components/Section.astro';

const description = 'AI Lean Solutions LLC builds and maintains practical AI systems, operating tools, and internal automation support.';
---

<Base title="home" description={description}>

  <section class="relative overflow-hidden pt-16 pb-20 md:pt-24 md:pb-28 bg-grain">
    <div class="aurora"></div>
    <div class="absolute inset-0 bg-grid opacity-50"></div>
    <div class="container-site relative">
      <div class="max-w-4xl">
        <p class="section-label mb-6">// AI Lean Solutions LLC</p>
        <h1 class="font-display font-bold tracking-tightest text-[clamp(2.4rem,7vw,5.8rem)] leading-[0.98] text-white">
          Practical AI for working better.
        </h1>
        <p class="mt-8 max-w-2xl text-[18px] md:text-[21px] text-text-muted leading-relaxed">
          AI Lean Solutions is simplifying its public presence and focusing current support
          through this company site.
        </p>
      </div>

      <div class="mt-16 grid gap-4 md:grid-cols-4">
        <div class="card p-5">
          <p class="font-mono text-[11px] uppercase tracking-label text-brand-cyan">Built around</p>
          <p class="mt-2 font-display text-2xl font-bold">AI + operations</p>
        </div>
        <div class="card p-5">
          <p class="font-mono text-[11px] uppercase tracking-label text-[#ffd23f]">Posture</p>
          <p class="mt-2 font-display text-2xl font-bold">Focused</p>
        </div>
        <div class="card p-5">
          <p class="font-mono text-[11px] uppercase tracking-label text-[#14b8a6]">Standard</p>
          <p class="mt-2 font-display text-2xl font-bold">Useful</p>
        </div>
        <div class="card p-5">
          <p class="font-mono text-[11px] uppercase tracking-label text-[#f97316]">Focus</p>
          <p class="mt-2 font-display text-2xl font-bold">Real work</p>
        </div>
      </div>
    </div>
  </section>

  <Section num="01" eyebrow="Current focus">
    <div class="grid gap-10 md:grid-cols-[0.9fr_1.2fr] md:items-start">
      <h2 class="font-display font-bold tracking-tightest text-4xl md:text-5xl leading-[1.05]">
        One supported public site.
      </h2>
      <div class="space-y-8">
        <div>
          <div class="font-mono text-[11px] uppercase tracking-label text-brand-cyan mb-3">01 · Plain language</div>
          <p class="text-text-muted text-[16px] leading-relaxed max-w-prose">
            The work should be understandable to regular people, not just technologists,
            consultants, or people already living inside AI tools.
          </p>
        </div>
        <div>
          <div class="font-mono text-[11px] uppercase tracking-label text-brand-cyan mb-3">02 · Useful systems</div>
          <p class="text-text-muted text-[16px] leading-relaxed max-w-prose">
            AI is valuable when it helps someone write, understand, organize, decide, follow up,
            or run a process with less wasted effort.
          </p>
        </div>
        <div>
          <div class="font-mono text-[11px] uppercase tracking-label text-brand-cyan mb-3">03 · Human judgment</div>
          <p class="text-text-muted text-[16px] leading-relaxed max-w-prose">
            AI can prepare drafts, checklists, summaries, and operating support. People still
            own decisions, accountability, customer relationships, and final judgment.
          </p>
        </div>
      </div>
    </div>
  </Section>

  <section class="relative overflow-hidden">
    <div class="container-site py-20 md:py-28">
      <div class="relative border border-white/8 bg-gradient-to-br from-ink-800 to-ink-900 p-8 md:p-12 overflow-hidden">
        <div class="absolute inset-x-0 top-0 h-1 bg-gradient-to-r from-brand-cyan via-[#ffd23f] to-[#f97316]"></div>
        <div class="relative max-w-2xl">
          <p class="section-label mb-4">Contact</p>
          <h2 class="font-display font-bold tracking-tightest text-4xl md:text-5xl leading-[1.05]">
            Current support runs through AI Lean Solutions.
          </h2>
          <p class="mt-5 text-text-muted text-[17px] leading-relaxed">
            Retired project sites have been parked. For current AI Lean Solutions work, use
            this site as the public source of truth.
          </p>
        </div>
      </div>
    </div>
  </section>

</Base>
