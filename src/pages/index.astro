---
import Base from '../layouts/Base.astro';
import Section from '../components/Section.astro';

const description = 'AI Lean Solutions LLC builds practical AI initiatives for small businesses, working professionals, and local service operators.';

const initiatives = [
  {
    label: 'Public AI adoption',
    title: 'AI Promotion Guy',
    href: '/ai-promotion-guy',
    accent: 'promotion',
    summary: 'Practical, positive AI education for everyday Americans and Main Street business owners.',
    proof: 'First useful wins before fear, hype, or jargon gets in the way.',
  },
  {
    label: 'Workflow improvement',
    title: 'UsefulOps AI',
    href: '/usefulops-ai',
    accent: 'usefulops',
    summary: 'Rowan Vale&rsquo;s autonomous AI-operated consulting business for owner-led teams.',
    proof: 'Less admin drag, clearer handoffs, better follow-up, and workflows people can actually use.',
  },
  {
    label: 'Market intelligence',
    title: 'Competitive Intelligence',
    href: '/market-intelligence',
    accent: 'market',
    summary: 'Weekly plain-language reports tracking the local competitors pulling from your customer pool.',
    proof: 'Currently live for Phoenix med spas, with more markets added carefully.',
  },
  {
    label: 'Field technician support',
    title: 'Expert Technician',
    href: '/expert-technician',
    accent: 'technician',
    summary: '24/7 AI-assisted technical and troubleshooting support for field technicians.',
    proof: 'Currently piloting for US-based HVAC technicians and service companies.',
  },
];
---

<Base title="home" description={description}>

  <section class="relative overflow-hidden pt-16 pb-20 md:pt-24 md:pb-28 bg-grain">
    <div class="aurora"></div>
    <div class="absolute inset-0 bg-grid opacity-50"></div>
    <div class="container-site relative">
      <div class="max-w-4xl">
        <p class="section-label mb-6">// AI Lean Solutions LLC</p>
        <h1 class="font-display font-bold tracking-tightest text-[clamp(2.4rem,7vw,5.8rem)] leading-[0.98] text-white">
          Practical AI initiatives for the businesses, workers, and communities ready to move.
        </h1>
        <p class="mt-8 max-w-2xl text-[18px] md:text-[21px] text-text-muted leading-relaxed">
          AI Lean Solutions builds focused AI-based programs that improve how people learn,
          work, compete, and get help in the field. Each initiative has its own personality.
          The operating philosophy is shared: useful first, clear next, human judgment always.
        </p>
        <div class="mt-10 flex flex-wrap items-center gap-3">
          <a href="#initiatives" class="btn-primary">
            Explore initiatives
            <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
              <path d="M6 2v8m-3-3 3 3 3-3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
          <a href="mailto:Brian.Bricker@AILeansolutions.com" class="btn-secondary">
            Contact Brian
          </a>
        </div>
      </div>

      <div class="mt-16 grid gap-4 md:grid-cols-4">
        <div class="card p-5">
          <p class="font-mono text-[11px] uppercase tracking-label text-brand-cyan">Built around</p>
          <p class="mt-2 font-display text-2xl font-bold">AI + operations</p>
        </div>
        <div class="card p-5">
          <p class="font-mono text-[11px] uppercase tracking-label text-[#ffd23f]">Posture</p>
          <p class="mt-2 font-display text-2xl font-bold">Optimistic</p>
        </div>
        <div class="card p-5">
          <p class="font-mono text-[11px] uppercase tracking-label text-[#14b8a6]">Standard</p>
          <p class="mt-2 font-display text-2xl font-bold">Useful</p>
        </div>
        <div class="card p-5">
          <p class="font-mono text-[11px] uppercase tracking-label text-[#f97316]">Focus</p>
          <p class="mt-2 font-display text-2xl font-bold">Real work</p>
        </div>
      </div>
    </div>
  </section>

  <Section num="01" eyebrow="Current initiatives" id="initiatives">
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-12">
      <h2 class="font-display font-bold tracking-tightest text-4xl md:text-5xl max-w-[18ch] leading-[1.05]">
        Four initiatives. One operating belief.
      </h2>
      <p class="text-text-muted text-[16px] max-w-md leading-relaxed">
        AI should help people get something done: a clearer message, a tighter workflow,
        a sharper market view, or a faster answer when the equipment is down.
      </p>
    </div>

    <div class="grid gap-5 md:grid-cols-2">
      {initiatives.map((item) => (
        <a href={item.href} class={`initiative-card initiative-card--${item.accent}`}>
          <span class="initiative-card__label">{item.label}</span>
          <h3>{item.title}</h3>
          <p set:html={item.summary}></p>
          <div class="initiative-card__proof" set:html={item.proof}></div>
          <span class="initiative-card__link">
            Learn more
            <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
              <path d="M2 6h8m-3-3 3 3-3 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </span>
        </a>
      ))}
    </div>
  </Section>

  <Section num="02" eyebrow="How we work">
    <div class="grid gap-10 md:grid-cols-[0.9fr_1.2fr] md:items-start">
      <h2 class="font-display font-bold tracking-tightest text-4xl md:text-5xl leading-[1.05]">
        Process improvement with AI in the toolbelt.
      </h2>
      <div class="space-y-8">
        <div>
          <div class="font-mono text-[11px] uppercase tracking-label text-brand-cyan mb-3">01 · Find the friction</div>
          <p class="text-text-muted text-[16px] leading-relaxed max-w-prose">
            The work starts with the actual bottleneck: repeated admin, unclear follow-up,
            lost market signal, field troubleshooting delays, or people unsure how to use AI safely.
          </p>
        </div>
        <div>
          <div class="font-mono text-[11px] uppercase tracking-label text-brand-cyan mb-3">02 · Build the first useful win</div>
          <p class="text-text-muted text-[16px] leading-relaxed max-w-prose">
            Big transformation talk is cheap. Each initiative is designed around small, practical
            wins that can be understood, tested, and improved.
          </p>
        </div>
        <div>
          <div class="font-mono text-[11px] uppercase tracking-label text-brand-cyan mb-3">03 · Keep humans responsible</div>
          <p class="text-text-muted text-[16px] leading-relaxed max-w-prose">
            AI can draft, summarize, route, monitor, and advise. People still own judgment,
            accountability, customer trust, and final decisions.
          </p>
        </div>
      </div>
    </div>
  </Section>

  <section class="relative overflow-hidden">
    <div class="container-site py-20 md:py-28">
      <div class="relative border border-white/8 bg-gradient-to-br from-ink-800 to-ink-900 p-8 md:p-12 overflow-hidden">
        <div class="absolute inset-x-0 top-0 h-1 bg-gradient-to-r from-brand-cyan via-[#ffd23f] to-[#f97316]"></div>
        <div class="relative max-w-2xl">
          <p class="section-label mb-4">Contact</p>
          <h2 class="font-display font-bold tracking-tightest text-4xl md:text-5xl leading-[1.05]">
            Interested in one of the initiatives?
          </h2>
          <p class="mt-5 text-text-muted text-[17px] leading-relaxed">
            Reach out to Brian Bricker at AI Lean Solutions. The current work spans public AI
            education, AI-operated workflow consulting, competitive intelligence, and HVAC
            technician support pilots.
          </p>
          <a href="mailto:Brian.Bricker@AILeansolutions.com" class="btn-primary mt-8">
            Email Brian
            <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
              <path d="M2 4.25 6 7l4-2.75M2.75 3h6.5c.69 0 1.25.56 1.25 1.25v4.5c0 .69-.56 1.25-1.25 1.25h-6.5C2.06 10 1.5 9.44 1.5 8.75v-4.5C1.5 3.56 2.06 3 2.75 3Z" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>

</Base>
