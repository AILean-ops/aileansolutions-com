---
import Base from '../layouts/Base.astro';

const description = "Tell us where you want competitive intelligence next. We're live in Phoenix for med spas — you're telling us where we go after that.";

/*
  FORM WIRING NOTE
  ----------------
  The form posts directly to Web3Forms (https://web3forms.com), a no-backend
  form-to-email service. Submissions land in Brian's aileansolutions.com Gmail.

  Access key: 638f05ca-f33a-4c10-bba2-cc0c4e757cb1
  - Public client-side identifier; safe to ship in HTML.
  - Web3Forms enforces security via referrer check (allowed domain:
    aileansolutions.com), not key secrecy.
  - Free tier: 250 submissions/mo combined across both forms (signup + contact).

  Pre-launch reminders (configure in the Web3Forms dashboard):
  - Add `aileansolutions.com` AND `www.aileansolutions.com` to allowed domains.
  - Disable any `localhost` allowance.
*/
---

<Base title="Waitlist" description={description}>

  <section class="relative overflow-hidden pt-16 pb-24 md:pt-24 md:pb-32 bg-grain">
    <div class="aurora"></div>
    <div class="container-site relative">

      <div class="max-w-2xl">
        <p class="section-label mb-5">// Waitlist</p>
        <h1 class="font-display font-bold tracking-tightest text-[clamp(2rem,6vw,4.5rem)] leading-[1.02]">
          Tell us where you want competitive intelligence next.
        </h1>
        <p class="mt-6 text-[17px] text-text-muted leading-relaxed">
          We&rsquo;re live in Phoenix for med spas. Every other market gets added in order
          of waitlist demand. You&rsquo;ll get one short email when we launch in your area.
          That&rsquo;s it &mdash; no monthly newsletter, no pitch.
        </p>
      </div>

      <!-- FORM -->
      <form
        id="waitlist-form"
        action="https://api.web3forms.com/submit"
        method="POST"
        novalidate
        class="mt-14 max-w-2xl grid gap-5"
      >
        <!-- Web3Forms hidden fields -->
        <input type="hidden" name="access_key" value="638f05ca-f33a-4c10-bba2-cc0c4e757cb1" />
        <input type="hidden" name="from_name" value="aileansolutions.com signup form" />
        <input type="hidden" name="subject" value="[Waitlist] aileansolutions.com signup" />
        <div class="grid md:grid-cols-2 gap-5">
          <label class="block">
            <span class="block font-mono text-[11px] uppercase tracking-label text-text-muted mb-2">Name</span>
            <input
              type="text"
              name="name"
              required
              autocomplete="name"
              class="w-full px-4 py-3 bg-ink-800 border border-white/10 rounded-lg font-sans text-white placeholder:text-text-dim focus:border-brand-cyan focus:outline-none focus:ring-2 focus:ring-brand-cyan/20 transition-colors"
              placeholder="Jamie Ortega"
            />
          </label>
          <label class="block">
            <span class="block font-mono text-[11px] uppercase tracking-label text-text-muted mb-2">Email</span>
            <input
              type="email"
              name="email"
              required
              autocomplete="email"
              class="w-full px-4 py-3 bg-ink-800 border border-white/10 rounded-lg font-sans text-white placeholder:text-text-dim focus:border-brand-cyan focus:outline-none focus:ring-2 focus:ring-brand-cyan/20 transition-colors"
              placeholder="jamie@studio.co"
            />
          </label>
        </div>

        <div class="grid md:grid-cols-2 gap-5">
          <label class="block">
            <span class="block font-mono text-[11px] uppercase tracking-label text-text-muted mb-2">Business type</span>
            <input
              type="text"
              name="business_type"
              required
              class="w-full px-4 py-3 bg-ink-800 border border-white/10 rounded-lg font-sans text-white placeholder:text-text-dim focus:border-brand-cyan focus:outline-none focus:ring-2 focus:ring-brand-cyan/20 transition-colors"
              placeholder="Med spa / dental / vet / HVAC / other"
            />
          </label>
          <label class="block">
            <span class="block font-mono text-[11px] uppercase tracking-label text-text-muted mb-2">City</span>
            <input
              type="text"
              name="city"
              required
              autocomplete="address-level2"
              class="w-full px-4 py-3 bg-ink-800 border border-white/10 rounded-lg font-sans text-white placeholder:text-text-dim focus:border-brand-cyan focus:outline-none focus:ring-2 focus:ring-brand-cyan/20 transition-colors"
              placeholder="Austin, TX"
            />
          </label>
        </div>

        <label class="block">
          <span class="block font-mono text-[11px] uppercase tracking-label text-text-muted mb-2">Anything else you want us to know? <span class="normal-case tracking-normal text-text-dim">(optional)</span></span>
          <textarea
            name="comment"
            rows="3"
            class="w-full px-4 py-3 bg-ink-800 border border-white/10 rounded-lg font-sans text-white placeholder:text-text-dim focus:border-brand-cyan focus:outline-none focus:ring-2 focus:ring-brand-cyan/20 transition-colors resize-none"
            placeholder="Who your competitors are, what's driving you nuts, what you'd want the report to include..."
          ></textarea>
        </label>

        <!-- Web3Forms honeypot (spam trap) -->
        <input type="checkbox" name="botcheck" style="display:none" tabindex="-1" autocomplete="off" />

        <div class="flex flex-wrap items-center gap-4 pt-2">
          <button type="submit" class="btn-primary">
            Join the waitlist
            <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
              <path d="M2 6h8m-3-3 3 3-3 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
          <p class="text-[13px] text-text-muted">
            No spam. No cold calls. Unsubscribe via link in any email.
          </p>
        </div>
      </form>

      <!-- THANK-YOU -->
      <div id="waitlist-thanks" class="hidden mt-14 max-w-2xl">
        <div class="card p-8 md:p-10">
          <div class="flex items-center gap-3 mb-5">
            <span class="inline-flex w-8 h-8 rounded-full bg-signal-up/15 text-signal-up items-center justify-center">
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                <path d="M2 7.5 5.5 11 12 3.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>
            <p class="font-mono text-[11px] uppercase tracking-label text-signal-up">You're on the list</p>
          </div>
          <h2 class="font-display text-3xl font-bold tracking-tight">Got you. Thanks.</h2>
          <p class="mt-4 text-text-muted text-[16px] leading-relaxed">
            Here's what actually happens next:
          </p>
          <ul class="mt-5 space-y-3 text-[15px]">
            <li class="flex gap-3"><span class="mt-1.5 inline-block w-1.5 h-1.5 rounded-full bg-brand-cyan flex-shrink-0"></span>A personal note from Brian within a few days &mdash; especially if your industry or city is close to where we&rsquo;re expanding next.</li>
            <li class="flex gap-3"><span class="mt-1.5 inline-block w-1.5 h-1.5 rounded-full bg-brand-cyan flex-shrink-0"></span>One launch notification the moment we go live in your area. That&rsquo;s it &mdash; we won&rsquo;t spam you in between.</li>
          </ul>
          <div class="hairline mt-8 pt-5 text-[13px] text-text-muted">
            Want to reach Brian sooner? <a href="mailto:Brian.Bricker@AILeansolutions.com" class="text-white underline underline-offset-4 decoration-white/30 hover:decoration-white">Email him directly</a>.
          </div>
        </div>
      </div>

      <!-- ERROR / FALLBACK -->
      <div id="waitlist-fallback" class="hidden mt-8 max-w-2xl">
        <div class="card p-6 border-amber-accent/30">
          <p class="text-[15px] leading-relaxed">
            Something went wrong submitting that form &mdash; please email Brian directly at
            <a href="mailto:Brian.Bricker@AILeansolutions.com?subject=Waitlist" class="text-brand-cyan underline underline-offset-4">
              Brian.Bricker@AILeansolutions.com</a> and we&rsquo;ll get you on the list.
          </p>
        </div>
      </div>

    </div>
  </section>

  <script is:inline>
    (function () {
      const form = document.getElementById('waitlist-form');
      const thanks = document.getElementById('waitlist-thanks');
      const fallback = document.getElementById('waitlist-fallback');
      if (!form) return;

      form.addEventListener('submit', async function (e) {
        e.preventDefault();
        // Honeypot — Web3Forms expects botcheck unchecked
        if (form.botcheck && form.botcheck.checked) return;

        const btn = form.querySelector('button[type=submit]');
        const originalLabel = btn.innerHTML;
        btn.disabled = true;
        btn.innerHTML = 'Joining…';

        try {
          const data = new FormData(form);
          // Web3Forms accepts JSON or FormData; JSON gives us cleaner success parsing.
          const obj = {};
          data.forEach((v, k) => { obj[k] = v; });
          const res = await fetch(form.action, {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
              Accept: 'application/json',
            },
            body: JSON.stringify(obj),
          });
          const json = await res.json().catch(() => ({}));
          if (!res.ok || json.success === false) throw new Error(json.message || 'not ok');
          form.classList.add('hidden');
          thanks.classList.remove('hidden');
          thanks.scrollIntoView({ behavior: 'smooth', block: 'start' });
        } catch (err) {
          btn.disabled = false;
          btn.innerHTML = originalLabel;
          fallback.classList.remove('hidden');
        }
      });
    })();
  </script>

</Base>
