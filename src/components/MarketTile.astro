---
interface Props {
  status: 'live' | 'soon' | 'waitlist';
  metro: string;
  vertical: string;
  note?: string;
  href?: string;
}
const { status, metro, vertical, note, href = '/signup' } = Astro.props;

const statusCopy = {
  live: { label: 'Live', color: 'text-signal-up', dot: 'bg-signal-up' },
  soon: { label: 'Opening next', color: 'text-brand-cyan', dot: 'bg-brand-cyan' },
  waitlist: { label: 'Coming next', color: 'text-text-muted', dot: 'bg-text-muted' },
};
const s = statusCopy[status];
const isPassive = status === 'waitlist';
---

<a
  href={href}
  class:list={[
    'group block card p-6 md:p-7 transition-all',
    isPassive ? 'border-dashed hover:border-solid' : '',
  ]}
>
  <div class="flex items-center gap-2 mb-4">
    <span class:list={['inline-block w-1.5 h-1.5 rounded-full', s.dot, status !== 'waitlist' ? 'animate-pulse-slow' : '']}></span>
    <span class:list={['font-mono text-[10px] uppercase tracking-label', s.color]}>
      {s.label}
    </span>
  </div>

  <div class="font-display text-xl font-semibold tracking-tight">
    {metro}
  </div>
  <div class="text-text-muted text-[14px] mt-0.5">
    {vertical}
  </div>

  {note && (
    <p class="mt-4 text-[13px] text-text-muted leading-relaxed">
      {note}
    </p>
  )}

  <div class="mt-5 flex items-center gap-1.5 text-[13px] font-medium text-white/80 group-hover:text-white transition-colors">
    {isPassive ? 'Join the waitlist' : 'Learn more'}
    <svg width="11" height="11" viewBox="0 0 10 10" fill="none" class="transition-transform group-hover:translate-x-0.5">
      <path d="M2 5h6m-2-2 2 2-2 2" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </div>
</a>
