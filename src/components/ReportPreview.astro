---
// Real screenshot of the sample report. Replace the file at
// /public/images/sample-report-preview-v2.png to update what visitors see.
// The whole component is wrapped in an <a> tag, so clicking the preview
// takes the visitor straight into the full report.
---

<a
  href="/sample-report/radiance-aesthetics.html"
  target="_blank"
  rel="noopener"
  class="block group relative card overflow-hidden shadow-2xl shadow-black/40 transition-transform hover:-translate-y-0.5 hover:shadow-brand-cyan/10"
  aria-label="Open the full sample report in a new tab"
>
  <!-- Window-chrome strip so it reads as 'a real document, framed' -->
  <div class="flex items-center justify-between px-4 py-3 border-b border-white/5 bg-ink-800/60">
    <div class="flex items-center gap-1.5">
      <span class="w-2.5 h-2.5 rounded-full bg-white/10"></span>
      <span class="w-2.5 h-2.5 rounded-full bg-white/10"></span>
      <span class="w-2.5 h-2.5 rounded-full bg-white/10"></span>
    </div>
    <div class="font-mono text-[10px] uppercase tracking-label text-text-muted">
      Weekly Intelligence · Sample Report
    </div>
    <div class="w-8"></div>
  </div>

  <!-- The real screenshot -->
  <div class="relative bg-paper-100">
    <img
      src="/images/sample-report-preview-v2.png"
      alt="Preview of a weekly competitive intelligence report"
      class="w-full h-auto block"
      loading="lazy"
      width="1100"
      height="900"
    />
    <!-- Soft fade at the bottom so it reads as 'continues beyond' -->
    <div class="absolute inset-x-0 bottom-0 h-32 bg-gradient-to-t from-ink-900 to-transparent pointer-events-none"></div>
  </div>

  <!-- Read-more strip -->
  <div class="flex items-center justify-between px-5 py-4 bg-ink-900 text-[13px]">
    <span class="font-mono uppercase tracking-label text-text-muted text-[11px]">
      Click to read the full report →
    </span>
    <span class="font-display font-medium text-white opacity-80 group-hover:opacity-100 transition-opacity">
      Open full sample
    </span>
  </div>
</a>
