---
const year = new Date().getFullYear();
---

<footer class="border-t border-white/5 mt-32 pb-10 pt-16 bg-ink-900">
  <div class="container-site">
    <div class="grid gap-10 md:grid-cols-[2fr_1fr_1fr]">
      <div>
        <div class="flex items-center gap-3 mb-4">
          <img src="/brand/logo.png" alt="AI Lean Solutions, LLC" class="w-10 h-10 object-contain" />
          <span class="font-display font-bold tracking-tight text-[17px] text-white">
            AI Lean Solutions, LLC
          </span>
        </div>
        <p class="text-text-muted text-[14px] max-w-xs leading-relaxed">
          Parent company for practical AI education and small-business workflow repair.
        </p>
        <div class="mt-4 inline-flex items-center gap-2 px-3 py-1.5 rounded-full border border-brand-cyan/30 bg-brand-cyan/5">
          <span class="inline-block w-2 h-2 rounded-full bg-signal-up animate-pulse-slow"></span>
          <span class="font-mono text-[11px] uppercase tracking-label text-white font-semibold">
            Building useful AI in public
          </span>
        </div>
      </div>

      <div>
        <p class="section-label mb-3">Initiatives</p>
        <ul class="space-y-2 text-[14px] text-text-muted">
          <li><a href="https://aipromotionguy.com/" class="hover:text-white transition-colors">AI Promotion Guy</a></li>
          <li><a href="https://usefulopsai.com/" class="hover:text-white transition-colors">UsefulOps AI</a></li>
        </ul>
      </div>

      <div>
        <p class="section-label mb-3">Legal</p>
        <ul class="space-y-2 text-[14px] text-text-muted">
          <li><a href="/legal/privacy" class="hover:text-white transition-colors">Privacy</a></li>
          <li><a href="/legal/terms" class="hover:text-white transition-colors">Terms</a></li>
        </ul>
      </div>
    </div>

    <div class="hairline-strong mt-12 pt-6 flex flex-col md:flex-row justify-between gap-3 text-[12px] text-text-dim">
      <p>© {year} AI Lean Solutions LLC. All rights reserved.</p>
      <p class="font-mono">AI Promotion Guy · UsefulOps AI</p>
    </div>
  </div>
</footer>
