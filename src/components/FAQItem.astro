---
interface Props {
  question: string;
}
const { question } = Astro.props;
---

<details class="group border-b border-white/8 py-5 first:border-t">
  <summary class="flex items-start justify-between gap-6 cursor-pointer list-none">
    <span class="font-display font-semibold text-[17px] md:text-[18px] leading-snug text-white">
      {question}
    </span>
    <span class="mt-0.5 flex-shrink-0 w-6 h-6 grid place-items-center rounded-full border border-white/15 text-text-muted group-open:rotate-45 transition-transform">
      <svg width="10" height="10" viewBox="0 0 10 10" fill="none" aria-hidden="true">
        <path d="M5 1v8M1 5h8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
    </span>
  </summary>
  <div class="mt-3 text-text-muted text-[15px] leading-relaxed max-w-prose">
    <slot />
  </div>
</details>
