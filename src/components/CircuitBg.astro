---
interface Props {
  opacity?: number;
  className?: string;
}
const { opacity = 0.25, className = '' } = Astro.props;
---

<svg
  class:list={['pointer-events-none select-none', className]}
  style={`opacity:${opacity}`}
  viewBox="0 0 1200 120"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  aria-hidden="true"
>
  <defs>
    <linearGradient id="circuit-g" x1="0" y1="0" x2="1200" y2="0" gradientUnits="userSpaceOnUse">
      <stop offset="0%" stop-color="#4FC3F7" stop-opacity="0"/>
      <stop offset="35%" stop-color="#4FC3F7"/>
      <stop offset="65%" stop-color="#1976D2"/>
      <stop offset="100%" stop-color="#1976D2" stop-opacity="0"/>
    </linearGradient>
  </defs>
  <g stroke="url(#circuit-g)" stroke-width="1">
    <path d="M0 60 L200 60 L220 40 L320 40 L340 60 L500 60 L520 80 L620 80 L640 60 L1200 60"/>
    <path d="M0 80 L140 80 L160 100 L1200 100" opacity="0.4"/>
    <path d="M0 40 L80 40 L100 20 L1200 20" opacity="0.3"/>
  </g>
  <g fill="url(#circuit-g)">
    <circle cx="220" cy="40" r="2.2"/>
    <circle cx="340" cy="60" r="2.2"/>
    <circle cx="520" cy="80" r="2.2"/>
    <circle cx="640" cy="60" r="2.2"/>
    <circle cx="800" cy="60" r="2.2"/>
    <circle cx="960" cy="60" r="2.2"/>
  </g>
</svg>
