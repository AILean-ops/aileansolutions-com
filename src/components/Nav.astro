---
const path = Astro.url.pathname.replace(/\/$/, '') || '/';
const links = [
  { href: '/', label: 'Home' },
  { href: '/product', label: 'Product' },
  { href: '/about', label: 'About' },
  { href: '/signup', label: 'Waitlist' },
  { href: '/contact', label: 'Contact' },
];
const isActive = (href: string) => {
  if (href === '/') return path === '/';
  return path.startsWith(href);
};
---

<header class="sticky top-0 z-50 backdrop-blur-md bg-ink-900/75 border-b border-white/5">
  <div class="container-site flex items-center justify-between h-20">
    <a href="/" class="flex items-center gap-3 group" aria-label="AI Lean Solutions, LLC — home">
      <span class="w-11 h-11 grid place-items-center">
        <img src="/brand/logo.png" alt="AI Lean Solutions, LLC" class="w-11 h-11 object-contain transition-transform duration-300 group-hover:rotate-[4deg]" />
      </span>
      <span class="font-display font-bold tracking-tight text-[19px] md:text-[21px] text-white">
        AI Lean Solutions, LLC
      </span>
    </a>

    <nav class="hidden md:flex items-center gap-8" aria-label="Primary">
      {links.slice(1).map((link) => (
        <a
          href={link.href}
          class="nav-link"
          aria-current={isActive(link.href) ? 'page' : undefined}
        >
          {link.label}
        </a>
      ))}
    </nav>

    <a
      href="/signup"
      class="hidden md:inline-flex items-center gap-1.5 font-display font-semibold text-[13px] px-3.5 py-2 rounded-full bg-white text-ink-900 hover:bg-paper-100 transition-colors"
    >
      Join waitlist
      <svg width="10" height="10" viewBox="0 0 10 10" fill="none" aria-hidden="true">
        <path d="M2 5h6m-2-2 2 2-2 2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </a>

    <!-- Mobile menu button (uses native <details>) -->
    <details class="md:hidden relative">
      <summary class="list-none cursor-pointer p-2 -mr-2" aria-label="Open menu">
        <svg width="22" height="22" viewBox="0 0 22 22" fill="none" aria-hidden="true">
          <path d="M3 6h16M3 11h16M3 16h16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
      </summary>
      <div class="absolute right-0 top-full mt-2 w-56 rounded-xl bg-ink-800 border border-white/10 p-2 shadow-2xl">
        {links.map((link) => (
          <a
            href={link.href}
            class="block px-3 py-2 rounded-md text-[14px] font-medium text-text-muted hover:text-white hover:bg-white/5 transition-colors"
            aria-current={isActive(link.href) ? 'page' : undefined}
          >
            {link.label}
          </a>
        ))}
        <div class="h-px bg-white/5 my-1"></div>
        <a
          href="/signup"
          class="block px-3 py-2 rounded-md text-[14px] font-semibold text-white bg-gradient-to-br from-brand-cyan to-brand-azure"
        >
          Join waitlist →
        </a>
      </div>
    </details>
  </div>
</header>
